# ============================================
# MeedyaConverter — .gitignore
# Covers: macOS, Windows, Linux, Xcode, VSCode,
#         Swift, Python, Node, Raspberry Pi dev
# (C) 2026 MWBM Partners Ltd
# ============================================

# --------------------
# macOS
# --------------------
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes

# --------------------
# Windows
# --------------------
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# --------------------
# Linux
# --------------------
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# --------------------
# Xcode
# --------------------
build/
DerivedData/
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3
xcuserdata/
*.xccheckout
*.moved-aside
*.hmap
*.ipa
*.dSYM.zip
*.dSYM
*.xcuserstate
*.xccovreport
*.xccovarchive

# Xcode project files (keep shared data)
*.xcworkspace
*.xcodeproj/*
!*.xcodeproj/project.pbxproj
!*.xcodeproj/xcshareddata/
!*.xcodeproj/project.xcworkspace/

# --------------------
# Swift Package Manager
# --------------------
.build/
Packages/
.swiftpm/xcode/package.xcworkspace/
.swiftpm/configuration/
Package.resolved

# --------------------
# CocoaPods
# --------------------
Pods/
Podfile.lock

# --------------------
# Carthage
# --------------------
Carthage/Build/
Carthage/Checkouts/

# --------------------
# fastlane
# --------------------
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/
fastlane/test_output/

# --------------------
# VSCode
# --------------------
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets
.history/
*.code-workspace

# --------------------
# Visual Studio (Windows)
# --------------------
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates
*.ncb
*.psess
*.vsp
*.vspscc
*.vssscc
ipch/
obj/
bin/
*.aps
*.pch

# --------------------
# JetBrains IDEs
# --------------------
.idea/
*.iml
*.iws
*.ipr
out/

# --------------------
# Python
# --------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pdb
*.pyc
.env
.venv/
env/
venv/
*.egg-info/
dist/
*.egg

# --------------------
# Node.js (for tooling)
# --------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm

# --------------------
# Logs & Temp files
# --------------------
*.log
*.tmp
*.bak
*.swp
*.swo
*~.nib

# --------------------
# Archives
# --------------------
*.zip
*.tar.gz
*.tgz
*.rar

# --------------------
# Media files (don't commit test media)
# --------------------
*.mp4
*.mkv
*.avi
*.mov
*.wmv
*.flv
*.webm
*.m4v
*.m4a
*.m4b
*.mp3
*.wav
*.flac
*.aac
*.ogg
*.opus
*.ts
*.m3u8
*.mpd

# --------------------
# Secrets & credentials
# --------------------
*.env
*.env.*
!*.env.example
credentials.json
secrets.json
*.pem
*.key
*.p12
*.p8

# --------------------
# Bundled tools (downloaded at build time)
# --------------------
Tools/ffmpeg
Tools/ffprobe
Tools/dovi_tool
Tools/ddvt
Tools/mp4box

# --------------------
# Build artifacts
# --------------------
*.dmg
*.pkg
*.app
*.ipa
*.exe
*.msi
*.deb
*.rpm
*.AppImage
*.flatpak
*.snap

# --------------------
# Coverage & profiling
# --------------------
*.gcda
*.gcno
*.gcov
coverage/
lcov.info
.nyc_output/
