<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>en</string>
    <key>CFBundleExecutable</key>
    <string>MeedyaConverter</string>
    <key>CFBundleIconFile</key>
    <!-- Filename (without extension) of the .icns in Contents/Resources/.
         scripts/generate-app-icns.sh assembles MeedyaConverter.icns from
         the AppIcon.appiconset PNG sources; the release.yml + testflight.yml
         workflows copy it into the bundle's Resources/ directory before
         signing. Without this key the App Store Connect validator rejects
         the build with ITMS-90236 (#390). -->
    <string>MeedyaConverter</string>
    <key>CFBundleIdentifier</key>
    <!-- Direct distribution bundle ID. CI substitutes Ltd.MWBMpartners.MeedyaConverter.Lite for App Store builds. -->
    <string>Ltd.MWBMpartners.MeedyaConverter</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>MeedyaConverter</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>0.1.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>LSMinimumSystemVersion</key>
    <string>15.0</string>
    <key>NSHumanReadableCopyright</key>
    <string>Copyright © 2026 MWBM Partners Ltd. All rights reserved.</string>
    <key>NSHighResolutionCapable</key>
    <true/>
    <key>LSApplicationCategoryType</key>
    <string>public.app-category.video</string>
    <key>NSSupportsAutomaticTermination</key>
    <false/>
    <key>NSSupportsSuddenTermination</key>
    <false/>
</dict>
</plist>
